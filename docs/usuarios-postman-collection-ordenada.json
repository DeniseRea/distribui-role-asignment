          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('userId', json.idPerson);",
              "if (json.persona && json.persona.idUuid) {",
              "  pm.collectionVariables.set('personaId', json.persona.idUuid);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
