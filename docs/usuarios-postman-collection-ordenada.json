  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Estado HTTP esperado', function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "roleId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "personaId",
      "value": ""
    }
  ],
  "item": [
